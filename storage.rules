rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userIsAdmin() {
      return isSignedIn() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function userIsPremium() {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.tier in ['vip1', 'vip2', 'premium', 'elite', 'expert_pro'];
    }

    // Verification Documents
    match /verifications/{userId}/{allPaths=**} {
      // Allow users to upload their own documents
      // Allow them to read their own documents
      allow read: if isOwner(userId) || userIsAdmin();
      allow create: if isOwner(userId) && 
        request.resource.size < 10 * 1024 * 1024 && // Max 10MB
        request.resource.contentType.matches('application/pdf|image/.*');
      
      // Prevent overwriting or deleting for audit purposes
      allow update, delete: if userIsAdmin();
    }

    // Profile Images (Publicly readable, owner writable)
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && 
        request.resource.size < 5 * 1024 * 1024 && // Max 5MB
        request.resource.contentType.matches('image/.*');
    }

    // Medical Vault (Private, owner only)
    match /vault/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || userIsAdmin();
      allow write: if isOwner(userId) && 
        (userIsPremium() || userIsAdmin()) &&
        request.resource.size < 20 * 1024 * 1024 && // Max 20MB
        request.resource.contentType.matches('application/pdf|image/.*');
    }
  }
}
